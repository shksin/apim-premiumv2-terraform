# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — do not commit real values.

# ── Required ─────────────────────────────────────────────────
publisher_email                = "admin@contoso.com"
publisher_name                 = "Contoso"
mcp_app_service_name           = "my-mcp-app-service"
mcp_app_service_resource_group = "rg-mcp-app"

