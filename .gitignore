# Terraform state — never commit
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform vars — may contain secrets
terraform.tfvars
*.auto.tfvars

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ad-hoc REST payloads
body.json

# Terraform plan binaries
tfplan*
*.tfplan

# Out-of-band App Service bootstrap scripts (run manually, not in TF pipeline)
scripts/

